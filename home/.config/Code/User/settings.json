{
    "files.associations": {
        "*.mpl": "maple",
        "**/macros/**/**": "rrf-gcode",
    },
    "window.titleBarStyle": "native",
    "editor.fontFamily": "JetBrains Mono, monospace",
    "editor.fontSize": 14,
    "editor.fontLigatures": true,
    "editor.mouseWheelZoom": true,
    "editor.foldingHighlight": false,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.rulers": [
        100,
        256
    ],
    "git.autofetch": true,
    "gitlens.currentLine.enabled": false,
    "gitlens.hovers.enabled": false,
    "gitlens.hovers.avatars": false,
    "gitlens.codeLens.enabled": false,
    "gitlens.codeLens.authors.enabled": false,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "editor.formatOnSave": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "git.confirmSync": false,
    "editor.tabMovesFocus": false,
    "[markdown]": {
        "diffEditor.ignoreTrimWhitespace": false
    },
    "makefile.configureOnOpen": true,
    "[maple]": {},
    "[rust]": {
        "editor.inlayHints.enabled": "off"
    },
    "zig.zls.enabled": "on",
    "codesnap.backgroundColor": "#FFFFFF",
    "codesnap.roundedCorners": false,
    "codesnap.showWindowTitle": false,
    "codesnap.showLineNumbers": false,
    "codesnap.boxShadow": "rgba(0, 0, 0, 0) 0px 0px 0px",
    "codesnap.showWindowControls": false,
    "codesnap.transparentBackground": true,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "workbench.editorAssociations": {
        "{hexdiff}:/**/*.*": "hexEditor.hexedit",
        "*.bin": "hexEditor.hexedit",
        "*.img": "hexEditor.hexedit",
        "*.elf": "elfpreview.elfViewer"
    },
    "xml.server.vmargs": "-Xmx128M",
    "cSpell.userWords": [
        "babystep",
        "babystepping",
        "baseload",
        "baseunload",
        "catf",
        "clientrc",
        "coef",
        "contron",
        "cooldown",
        "dimmwhite",
        "DMOJ",
        "elif",
        "endstop",
        "Endstops",
        "etpc",
        "evtype",
        "feedrate",
        "fileexists",
        "fileread",
        "ftxui",
        "gcode",
        "Gcodes",
        "heightmap",
        "hepa",
        "homeall",
        "Hotend",
        "hyprctl",
        "invlpg",
        "leadscrews",
        "microstepping",
        "myftxui",
        "mymacro",
        "ncinput",
        "nckey",
        "NCMICE",
        "ncplane",
        "networktest",
        "notcurses",
        "nozzlewipe",
        "onclick",
        "prio",
        "pson",
        "pthread",
        "Remenod",
        "reprap",
        "reprapfirmware",
        "resetstatus",
        "resetzbabystep",
        "rrfgcode",
        "runonce",
        "standartize",
        "statusoff",
        "tabset",
        "tinyexpr",
        "tooltemp",
        "Voronoi",
        "Wextra"
    ],
    "explorer.confirmDelete": false,
    "go.inlayHints.ignoredError": true,
    "chat.disableAIFeatures": true,
    "diffEditor.maxComputationTime": 0
}